# Normalize line endings — LF in the repo, everywhere.
* text=auto eol=lf

# Explicit text
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.svg   text eol=lf

# Binary assets — never touch
*.jpg   binary
*.jpeg  binary
*.png   binary
*.webp  binary
*.woff2 binary
*.pdf   binary
